# Development defaults — these are picked up by `just web` / `npm run dev`.
# CP_ORIGIN and AS_ORIGIN are intentionally empty: the vite proxy forwards /cp.v1.*
# and /ws/* to 127.0.0.1:8080, so relative URLs work out-of-the-box.
VITE_CP_ORIGIN=
VITE_AS_ORIGIN=
# Dev bearer token. NEVER hardcode this value in TypeScript source — Vite inlines the
# env var at build time, so release builds use the GitHub secret instead (see web-release.yml).
VITE_AUTH_TOKEN=dev-token
