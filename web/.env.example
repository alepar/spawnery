# Production build environment variables.
# Copy to .env.production and fill in the real origins before running `npm run build`.
# These are baked into the bundle at build time and pin the CSP connect-src directive —
# the browser physically cannot contact any other origin once the bundle is signed.
#
# See deploy/web/README.md for the full ops checklist.

# Canonical CP API origin (https, no trailing slash).
# Example: https://cp.spawnery.dev
VITE_CP_ORIGIN=https://cp.example.spawnery.dev

# Canonical AS (Account Service) origin (https, no trailing slash).
# Example: https://as.spawnery.dev
VITE_AS_ORIGIN=https://as.example.spawnery.dev
