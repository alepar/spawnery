  "compilerOptions": {
    "target": "ES2020", "useDefineForClassFields": true, "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "ESNext", "skipLibCheck": true, "moduleResolution": "bundler",
    "strict": true, "jsx": "react-jsx", "noEmit": true, "esModuleInterop": true
  },
  "include": ["src"]
}
