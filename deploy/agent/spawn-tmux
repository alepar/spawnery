#!/bin/sh
# Launch the agent TUI inside a detached tmux session named "spawn", then block so the container
# (PID 1) stays alive while clients attach via `tmux attach -t spawn`. Args are the agent argv.
set -e
SESSION="${SPAWN_TMUX_SESSION:-spawn}"
export TERM="${TERM:-xterm-256color}"
tmux -u new-session -d -s "$SESSION" -- "$@"
# Keep PID 1 alive while the tmux session exists (clients attach via `tmux attach -t spawn`). When the
# agent exits, its window closes, the session ends, and this loop returns so PID 1 exits and the node
# reaps the pod. (`tmux wait-for` was wrong here — nothing ever signals its channel, so it blocks
# forever even after the agent dies.)
while tmux has-session -t "$SESSION" 2>/dev/null; do
  sleep 1
done
