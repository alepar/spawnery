
# Beads / Dolt files (added by bd init)
.dolt/
*.db
cp.db*
.beads-credential-key

/bin/
/.spawns/
/.envs/
# stray root-level build outputs (use /bin/ instead)
/spawnlet
/spawnctl
/sidecar
/stubagent
*.test
*.out
.env
.env.*
# env.example and .env.development have no secrets — committed as documentation.
!.env.example
!web/.env.example
!web/.env.development
/.make/
/cp
/authsvc
/spawnery-ca
/telemetry/
# local dev CA material (private keys) — never commit.
# NOTE: the comment is on its own line; an inline "# ..." after a pattern is treated as a literal
# part of the pattern by gitignore, which silently un-ignores the path.
/.dev-ca/

# local dev-lane process logs (just-launched components write here)
/.logs/

# Syncthing conflict artifacts in the externally-synced .beads dir (not source of truth)
.beads/*.sync-conflict-*

# Beads JSONL exports (issues.jsonl, interactions.jsonl, …) — passive, regenerable exports of the
# Dolt DB (the source of truth, synced via refs/dolt/data). NOT tracked in git: they churn on every
# bd op and have a bad concurrent-merge story. Auto-export is disabled (export.auto/git-add=false in
# .beads/config.yaml). Off-machine recovery is the local .beads/backup/ dir, not git.
.beads/*.jsonl

# Local git worktrees (linked checkouts; not part of the tracked tree)
.worktrees/
.claude/worktrees/
.superpowers/
deploy/garage/dev-creds.env
